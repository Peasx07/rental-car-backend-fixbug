    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "1. User Registration",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 or 201\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success === true && jsonData.token) {",
                  "    pm.environment.set(\"user_token\", jsonData.token);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "",
                  "let generatedEmail = pm.variables.replaceIn('{{$randomEmail}}');",
                  "pm.environment.set(\"registered_email\", generatedEmail);",
                  "",
                  "// เก็บพาสเวิร์ดไว้ด้วย (เผื่ออนาคตอยากเปลี่ยนจะได้เปลี่ยนที่เดียว)",
                  "pm.environment.set(\"registered_password\", \"123456\");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Test User\",\n    \"telephone\": \"0899999999\",\n    \"email\": \"{{registered_email}}\",\n    \"password\": \"{{registered_password}}\",\n    \"role\": \"user\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{url}}/auth/register",
              "host": [
                "{{url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "2. User Log-in",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
