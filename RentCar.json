                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "if (pm.response.code === 200 && jsonData.success === true) {",
                  "    pm.environment.set(\"user_token\", jsonData.token);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{registered_email}}\",\n    \"password\": \"{{registered_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
