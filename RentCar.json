          "name": "3. User View Product (Cars)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "if(jsonData.data && jsonData.data.length > 0) {",
                  "   pm.environment.set(\"car_id\", jsonData.data[0]._id);",
                  "   var provider = jsonData.data[0].provider;",
                  "   pm.environment.set(\"provider_id\", provider._id ? provider._id : provider);",
                  "}",
                  "",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{user_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{url}}/cars",
              "host": [
                "{{url}}"
              ],
              "path": [
                "cars"
              ]
            }
          },
          "response": []
